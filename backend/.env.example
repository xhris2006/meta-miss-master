# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/metamissmaster?schema=public"

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars

# ── Flutterwave ──────────────────────────────────────────
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_HASH=your_flutterwave_webhook_hash_secret
FLW_ENCRYPTION_KEY=your_flutterwave_encryption_key

# ── Frontend URL (for CORS + redirect) ───────────────────
FRONTEND_URL=http://localhost:3000

# ── Logs ─────────────────────────────────────────────────
LOG_LEVEL=info
